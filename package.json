{
  "name": "postmx",
  "version": "0.1.1",
  "description": "Official PostMX Node.js SDK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/postmx/node.git"
  },
  "homepage": "https://github.com/postmx/node",
  "bugs": "https://github.com/postmx/node/issues",
  "author": "postmx <dev@postmx.co>",
  "keywords": ["postmx", "email", "inbox", "otp", "sdk"],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "postmx": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
